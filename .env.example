# Copy these into Vercel → Project → Settings → Environment Variables
# (Production + Preview). Do NOT commit real values — .env* is gitignored.
# Generate the secret ones with:  npm run gen-secrets "your admin passphrase"

# --- Database (Turso) — required for persistence ---
TURSO_DATABASE_URL=libsql://your-db.turso.io
TURSO_AUTH_TOKEN=

# --- App secrets (from npm run gen-secrets) ---
EMAIL_ENC_KEY=          # 32-byte hex — AES-256-GCM key for emails at rest
HMAC_SECRET=            # signs removal-link tokens
SESSION_SECRET=         # signs admin session cookies
RATE_LIMIT_SALT=        # salts IP hashes in the rate limiter
CRON_SECRET=            # guards /api/cron/daily (Vercel sends it as a Bearer token)

# --- Admin login (from npm run gen-secrets) ---
ADMIN_PASSWORD_HASH=    # scrypt "salt:hash"
ADMIN_TOTP_SECRET=      # base32 TOTP secret (enroll in your authenticator app)

# --- Anti-spam (Cloudflare Turnstile) ---
TURNSTILE_SITE_KEY=     # public, returned to the browser
TURNSTILE_SECRET_KEY=   # private, server-side verification

# --- Email (Resend) — OPTIONAL; removal link also shows on-screen ---
RESEND_API_KEY=
RESEND_FROM=notes@yourdomain.com

# --- Misc ---
SITE_URL=https://beforeaistealsmyjob.vercel.app
MODERATION_MODE=        # empty = notes go live; "pending" = hold for admin approval

# --- Moderation (optional) ---
# Comma-separated terms to block in notes (case-insensitive, whole-word).
# PII (email/phone/card/ID) is always blocked regardless of this list.
BLOCKLIST_TERMS=

# --- Off-box backup (optional) ---
# If set, the nightly cron POSTs a full JSON dump here (e.g. a Cloudflare
# Worker that writes the body to R2, or any S3-signed upload proxy).
BACKUP_WEBHOOK_URL=
BACKUP_WEBHOOK_SECRET=   # optional; sent as "Authorization: Bearer <secret>"
